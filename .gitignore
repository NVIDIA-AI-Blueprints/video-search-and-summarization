.claude

# Python
__pycache__/
*.pyc

# OpenClaw plugin pack artifacts (staged by .openclaw/package.json prepack)
.openclaw/*.tgz
.openclaw/.skills.staged

# Runtime artifacts from the deploy flow — these carry live credentials
# (NGC_CLI_API_KEY, NVIDIA_API_KEY, etc.) and resolved compose state,
# so they must never be committed. Generated by dev-profile.sh / the
# vss-deploy-profile skill on every deploy.
**/generated.env
deploy/docker/resolved.yml

*.log
*checkpoint.*
.orchestrator-artifacts/*
