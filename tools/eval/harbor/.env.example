# =============================================================================
# Harbor Eval Environment Variables
# Copy to .env at repo root and fill in values.
# =============================================================================

# --- Required: Claude Code API access ---
# Direct Anthropic API:
#   ANTHROPIC_API_KEY=sk-ant-api03-...
#
# NVIDIA Inference API proxy:
#   ANTHROPIC_API_KEY=sk-...
#   ANTHROPIC_BASE_URL=https://inference-api.nvidia.com
#   ANTHROPIC_MODEL=us/aws/anthropic/bedrock-claude-opus-4-6

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# --- Optional: Brev instance ---
# Name of pre-existing Brev instance (skips creation if set)
# BREV_INSTANCE=my-eval-gpu
# Instance type for auto-creation (default: l40s-48gb.1x)
# BREV_INSTANCE_TYPE=l40s-48gb.1x

# --- Optional: NGC / NVIDIA API keys (for VSS deployment) ---
# NGC_CLI_API_KEY=nvapi-...
# NVIDIA_API_KEY=nvapi-...

# --- Required for edge platforms (DGX Spark / AGX Thor / IGX Thor) ---
# Hugging Face token — used by the Nemotron Edge 4B vLLM container to pull
# model weights. See skills/deploy/references/edge.md.
# HF_TOKEN=hf_...

# --- Optional: Remote LLM / VLM endpoints ---
# If set, the generator emits `remote-*` deploy tasks using these endpoints.
# URLs must NOT end in /v1 — VSS's config.yml appends /v1 automatically.
# LLM_REMOTE_URL=http://global.stg.ga.launchpad.nvidia.com:11571
# LLM_REMOTE_MODEL=nvidia/nvidia-nemotron-nano-9b-v2
# VLM_REMOTE_URL=http://global.stg.ga.launchpad.nvidia.com:11857
# VLM_REMOTE_MODEL=nvidia/cosmos-reason2-8b

# --- Required for the coordinator agent (tools/eval/harbor/AGENTS.md) ---
# Only used when this repo is driven by the eval coordinator running at
# ~/eval-coordinator/. Unused for manual harbor runs.
#
# GitHub PAT for `gh` (PR comments + adapter PRs); needs `repo` scope.
# GITHUB_TOKEN=ghp_...
#
# Author identity propagated to GIT_AUTHOR_* / GIT_COMMITTER_* per process.
# The coordinator host's git config is intentionally not set globally.
# GIT_USER_NAME=Your Name
# GIT_USER_EMAIL=you@example.com
