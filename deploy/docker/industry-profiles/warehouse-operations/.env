# =============================================================================
# WAREHOUSE BLUEPRINT ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains environment variables for the warehouse blueprint.
# Services: Foundational, VST, Warehouse 2D/3D apps, VLM (optional), Agents (optional)
#
# Profile variants:
# 2d:
#   bp_wh
#   bp_wh_kafka
#   bp_wh_redis
# 3d:
#   bp_wh_kafka
#   bp_wh_redis
# =============================================================================

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# These variables control which services are deployed
# User should modify these based on deployment requirements

# Deployment mode: 2d or 3d
MODE=2d

# Blueprint profile: bp_wh, bp_wh_kafka, bp_wh_redis
BP_PROFILE=bp_wh

# Minimal profile applies to bp_wh_kafka and bp_wh_redis.
# Minimal profile is recommended for Thor deployment.
# For minimal profile, set MINIMAL_PROFILE="true" (excludes ELK, Video Analytics API/UI, monitoring and their dependent services).
# For extended profile, set MINIMAL_PROFILE="" or leave it unset. 
MINIMAL_PROFILE="true" # Minimal profile
# MINIMAL_PROFILE=""     # extended profile

# For 2d:
#   SAMPLE_VIDEO_DATASET=nv-warehouse-4cams (NUM_STREAMS=4) - applicable for BP_PROFILE=bp_wh only
#   SAMPLE_VIDEO_DATASET=warehouse-loading-dock-3cams-synthetic (NUM_STREAMS=3) - applicable for bp_wh_kafka and bp_wh_redis
# For 3d:
#   SAMPLE_VIDEO_DATASET=warehouse-4cams-20mx20m-synthetic (NUM_STREAMS=4) - applicable for bp_wh_kafka and bp_wh_redis
SAMPLE_VIDEO_DATASET="nv-warehouse-4cams"

# Hardware profile for NIM and DS configuration optimization
# Valid values: H100, L40, L40S, L4, A6000, RTXPRO6000BW, IGX-THOR, DGX-SPARK
# DO NOT use higher profile value on lower profile hardware (e.g., H100 on L4)
HARDWARE_PROFILE=H100

RT_CV_DEVICE_ID='0'
RT_VLM_DEVICE_ID='1'
LLM_DEVICE_ID='2'
VLM_DEVICE_ID='1'
SHARED_LLM_VLM_DEVICE_ID='2'

# LLM_MODE and VLM_MODE for deployment: local/local_shared (deploy NIMs locally) or remote (use remote NIM endpoints)
# For local: requires NGC_CLI_API_KEY
# For local_shared: requires NGC_CLI_API_KEY, runs LLM and VLM on single GPU
# For remote: requires LLM_BASE_URL and VLM_BASE_URL to be configured
# Set none: If NIM deployment is not required
# LLM_MODE and VLM_MODE is only needed for BP_PROFILE=bp_wh (Choose options from local,local_shared or remote), Set LLM_MODE=none and VLM_MODE=none for BP_PROFILE=bp_wh_kafka, BP_PROFILE=bp_wh_redis
LLM_MODE=local
VLM_MODE=local

# LLM options:
# - LLM_NAME: nvidia/nvidia-nemotron-nano-9b-v2
#   LLM_NAME_SLUG: nvidia-nemotron-nano-9b-v2
# - LLM_NAME: nvidia/nemotron-3-nano
#   LLM_NAME_SLUG: nemotron-3-nano
# - LLM_NAME: nvidia/llama-3.3-nemotron-super-49b-v1.5
#   LLM_NAME_SLUG: llama-3.3-nemotron-super-49b-v1.5
# - LLM_NAME: openai/gpt-oss-20b
#   LLM_NAME_SLUG: gpt-oss-20b
LLM_NAME=nvidia/nvidia-nemotron-nano-9b-v2
LLM_NAME_SLUG=nvidia-nemotron-nano-9b-v2
LLM_ENV_FILE=''
LLM_BASE_URL=''
LLM_MODEL_TYPE=nim

# VLM options:
# - VLM_NAME: nvidia/cosmos-reason1-7b
#   VLM_NAME_SLUG: cosmos-reason1-7b
# - VLM_NAME: nvidia/cosmos-reason2-8b
#   VLM_NAME_SLUG: cosmos-reason2-8b
# - VLM_NAME: Qwen/Qwen3-VL-8B-Instruct
#   VLM_NAME_SLUG: qwen3-vl-8b-instruct

VLM_NAME=nim_nvidia_cosmos-reason2-8b_hf-1208
VLM_NAME_SLUG=none

VLM_ENV_FILE=''
VLM_MODEL_TYPE=nim

RTVI_VLM_MODEL_PATH=ngc:nim/nvidia/cosmos-reason2-8b:hf-1208
RTVI_VLM_MODEL_TO_USE=cosmos-reason2

# =============================================================================
# SERVICE COMPOSITION — Profile inversion model
# =============================================================================
# Base services shared across all warehouse variants
_WH_BASE=redis,vss-auto-calibration-ui,vss-auto-calibration,centralizedb,vst-ingress,vst-mcp,sensor-bp-wait-bp-configurator,sdr-streamprocessing,envoy-streamprocessing
# Kafka transport services
_WH_KAFKA=kafka,kafka-topic-init-container
# Extended (non-minimal) services
_WH_EXTENDED_COMMON=elasticsearch,elasticsearch-init-container,vss-haproxy-ingress,dcgm-exporter,prometheus,grafana,node-exporter,cadvisor
# 2D warehouse app services
_WH_2D_APP=vss-behavior-analytics-2d,nvstreamer-2d,perception-sdr-2d,bp-configurator-2d,ds-configurator-2d,perception-2d,streamprocessing-ms-2d,sensor-ms-2d
# 3D warehouse app services
_WH_3D_APP=vss-behavior-analytics-3d,nvstreamer-3d,perception-sdr-3d,bp-configurator-3d,ds-configurator-3d,perception-3d,streamprocessing-ms-3d,sensor-ms-3d
# Extended 2D services (omitted in minimal mode)
_WH_2D_EXTENDED=kibana,logstash,kibana-init-container-2d,vss-video-analytics-api-2d,import-calibration-output-container-2d
# Extended 3D services (omitted in minimal mode)
_WH_3D_EXTENDED=kibana,logstash,kibana-init-container-3d,vss-video-analytics-api-3d,import-calibration-output-container-3d
# bp_wh_2d only: agent, UI, alerts, rtvi-vlm (LLM appended by script)
_WH_2D_FULL_ONLY=vss-ui,vss-agent,rtvi-vlm,alert-bridge,perception-sdr-alerts-2d

# Playback 2D services
_WH_PLAYBACK_2D_APP=vss-behavior-analytics-playback-2d,streamprocessing-ms-2d,sensor-ms-2d
# Playback 3D services
_WH_PLAYBACK_3D_APP=vss-behavior-analytics-playback-3d,streamprocessing-ms-3d,sensor-ms-3d

# --- Per-variant COMPOSE_PROFILES (non-minimal) ---
COMPOSE_PROFILES_WH_2D=${_WH_BASE},${_WH_KAFKA},${_WH_2D_APP},${_WH_2D_FULL_ONLY},${_WH_EXTENDED_COMMON},${_WH_2D_EXTENDED},llm_${LLM_MODE}_${LLM_NAME_SLUG}
COMPOSE_PROFILES_WH_KAFKA_2D=${_WH_BASE},${_WH_KAFKA},${_WH_2D_APP},${_WH_EXTENDED_COMMON},${_WH_2D_EXTENDED}
COMPOSE_PROFILES_WH_REDIS_2D=${_WH_BASE},${_WH_2D_APP},${_WH_EXTENDED_COMMON},${_WH_2D_EXTENDED}
COMPOSE_PROFILES_WH_KAFKA_3D=${_WH_BASE},${_WH_KAFKA},${_WH_3D_APP},${_WH_EXTENDED_COMMON},${_WH_3D_EXTENDED}
COMPOSE_PROFILES_WH_REDIS_3D=${_WH_BASE},${_WH_3D_APP},${_WH_EXTENDED_COMMON},${_WH_3D_EXTENDED}

# --- Minimal variants (no ELK, no monitoring, no extended) ---
COMPOSE_PROFILES_WH_2D_MINIMAL=${_WH_BASE},${_WH_KAFKA},${_WH_2D_APP},${_WH_2D_FULL_ONLY},llm_${LLM_MODE}_${LLM_NAME_SLUG}
COMPOSE_PROFILES_WH_KAFKA_2D_MINIMAL=${_WH_BASE},${_WH_KAFKA},${_WH_2D_APP}
COMPOSE_PROFILES_WH_REDIS_2D_MINIMAL=${_WH_BASE},${_WH_2D_APP}
COMPOSE_PROFILES_WH_KAFKA_3D_MINIMAL=${_WH_BASE},${_WH_KAFKA},${_WH_3D_APP}
COMPOSE_PROFILES_WH_REDIS_3D_MINIMAL=${_WH_BASE},${_WH_3D_APP}

# --- Playback variants ---
COMPOSE_PROFILES_PLAYBACK_KAFKA_2D=${_WH_BASE},${_WH_KAFKA},${_WH_PLAYBACK_2D_APP},${_WH_EXTENDED_COMMON},${_WH_2D_EXTENDED}
COMPOSE_PROFILES_PLAYBACK_REDIS_2D=${_WH_BASE},${_WH_PLAYBACK_2D_APP},${_WH_EXTENDED_COMMON},${_WH_2D_EXTENDED}
COMPOSE_PROFILES_PLAYBACK_KAFKA_3D=${_WH_BASE},${_WH_KAFKA},${_WH_PLAYBACK_3D_APP},${_WH_EXTENDED_COMMON},${_WH_3D_EXTENDED}
COMPOSE_PROFILES_PLAYBACK_REDIS_3D=${_WH_BASE},${_WH_PLAYBACK_3D_APP},${_WH_EXTENDED_COMMON},${_WH_3D_EXTENDED}

# Active profile (script updates this based on BP_PROFILE, MODE, and MINIMAL_PROFILE)
COMPOSE_PROFILES=${COMPOSE_PROFILES_WH_2D}

# OpenTelemetry Configuration
OTEL_SDK_DISABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_METRICS_EXPORTER=otlp

# =============================================================================
# CORE INFRASTRUCTURE PATHS
# =============================================================================
# Used by: Foundational services, VST, Warehouse apps, VLM, Agents
# User MUST modify these paths

# Path to deployments directory
MDX_SAMPLE_APPS_DIR="/path/to/deployments"

# Path to data directory (for models, videos, data logs)
MDX_DATA_DIR="/path/to/vss-warehouse-app-data"

# Host IP address for networking
HOST_IP='<HOST_IP>'
EXTERNAL_IP="${HOST_IP}"

# HAProxy ingress
HAPROXY_PORT=7777
VSS_PUBLIC_HTTP_PROTOCOL=http
VSS_PUBLIC_WS_PROTOCOL=ws
VSS_PUBLIC_HOST=${EXTERNAL_IP}
VSS_PUBLIC_PORT=${HAPROXY_PORT}

# =============================================================================
# ELASTICSEARCH CONFIGURATION
# =============================================================================

# Elasticsearch ILM policy retention period
ELASTICSEARCH_ILM_MIN_AGE=4h

# Maximum number of attempts to connect to Elasticsearch
ELASTICSEARCH_CONNECTION_MAX_ATTEMPTS=20

# =============================================================================
# API KEYS & CREDENTIALS
# =============================================================================

# NGC CLI API Key (REQUIRED for local LLM / VLM deployment)
# Obtain from: https://ngc.nvidia.com/
NGC_CLI_API_KEY=''

# NVIDIA API Key (REQUIRED for build.nvidia.com remote LLM / VLM endpoints)
# Obtain from: https://build.nvidia.com/
NVIDIA_API_KEY=''

# OPENAI API Key (REQUIRED for openai remote LLM / VLM endpoints)
# Obtain from: https://platform.openai.com/
OPENAI_API_KEY=''

# =============================================================================
# MESSAGE BROKER CONFIGURATION
# =============================================================================
# Used by: Foundational services, VST, Warehouse apps

# Message broker type: kafka or redis
STREAM_TYPE=kafka

# =============================================================================
# HARDWARE & PERCEPTION CONFIGURATION
# =============================================================================
# Used by: Warehouse perception and analytics services

# Perception container image and tag
PERCEPTION_IMAGE="nvcr.io/nvstaging/vss-core/vss-rt-cv"
# For multi-arch: 3.2.0-<version>
PERCEPTION_TAG="3.2.0-26.04.2"
# For DGX-SPARK (SBSA): 3.2.0-sbsa-<version> Uncomment below and comment above
# PERCEPTION_TAG="3.2.0-sbsa-26.04.3"

# Number of concurrent streams to process
NUM_STREAMS=4

# =============================================================================
# NVSTREAMER CONFIGURATION
# =============================================================================
# Used by: nvstreamer-2d, nvstreamer-3d

# Install additional packages for audio, software encoding, file upload
NVSTREAMER_INSTALL_ADDITIONAL_PACKAGES=true

# Nvstreamer HTTP port
NVSTREAMER_HTTP_PORT=31000

# Nvstreamer IP
NVSTREAMER_IP=localhost # localhost if Nvstreamer is on the same host as the warehouse app; otherwise, the IP address of the Nvstreamer host

# =============================================================================
# DOCKER COMPOSE CONFIGURATION
# =============================================================================

# Project name for volume naming (DO NOT MODIFY)
COMPOSE_PROJECT_NAME=mdx

# =============================================================================
# VLM-AS-VERIFIER CONFIGURATION
# =============================================================================
# Used by: alert-bridge service

VLM_AS_VERIFIER_CONFIG_FILE=${MDX_SAMPLE_APPS_DIR}/industry-profiles/warehouse-operations/vlm-as-verifier/configs/config.yml
VLM_AS_VERIFIER_CONFIG_FILE_REALTIME=${MDX_SAMPLE_APPS_DIR}/industry-profiles/warehouse-operations/vlm-as-verifier/realtime-config.yml
VLM_AS_VERIFIER_ALERT_TYPE_CONFIG_FILE=${MDX_SAMPLE_APPS_DIR}/industry-profiles/warehouse-operations/vlm-as-verifier/configs/alert_type_config.json

# =============================================================================
# NIM CONFIGURATION
# =============================================================================
# Used by: vss-agent, alert-bridge

# LLM Configuration
LLM_PORT=30081

# VLM Configuration
VLM_PORT=30082

VLM_NIM_KVCACHE_PERCENT="0.7"
# Custom model weights (optional)
# VLM_CUSTOM_WEIGHTS=""

# =============================================================================
# VSS AGENT CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-va-mcp, vss-ui services

# VSS Agent Core
VSS_AGENT_VERSION=3.2.0-26.05.1-4648c6ac8160
VSS_AGENT_CONFIG_FILE=./deploy/docker/industry-profiles/warehouse-operations/vss-agent/configs/config.yml
VSS_AGENT_HOST=0.0.0.0
VSS_AGENT_PORT=8000

# VSS Video Analysis MCP Server
VSS_VA_MCP_CONFIG_FILE=./deploy/docker/industry-profiles/warehouse-operations/vss-agent/configs/va_mcp_server_config.yml
VSS_VA_MCP_PORT=9901

# VSS Agent Templates
VSS_AGENT_TEMPLATE_PATH=./deploy/docker/industry-profiles/warehouse-operations/vss-agent/templates
VSS_AGENT_TEMPLATE_NAME=incident_report_template.md

# Video Analytics API Port
MDX_PORT=8081

# =============================================================================
# VST (VIDEO STORAGE TOOL) CONFIGURATION
# =============================================================================
# Used by: vss-agent, vss-ui

# VST Base Configuration
VST_PORT=30888
VST_EXTERNAL_URL=${VSS_PUBLIC_HTTP_PROTOCOL}://${VSS_PUBLIC_HOST}:${VSS_PUBLIC_PORT}
VST_INTERNAL_URL=http://${HOST_IP}:${VST_PORT}
VST_IP=localhost # localhost if VST is on the same host as the warehouse app; otherwise, the IP address of the VST host

# VST MCP Configuration
VST_MCP_PORT=8001
VST_MCP_URL=http://${HOST_IP}:${VST_MCP_PORT}

# VST Image tags for common all platforms
VST_STREAM_PROCESSOR_IMAGE_TAG="2.1.0-26.04.1"
VST_SENSOR_IMAGE_TAG="2.1.0-26.04.1"
NVSTREAMER_IMAGE_TAG="2.1.0-26.04.1"
VST_MCP_IMAGE_TAG="2.1.0-26.04.1"
VST_INGRESS_IMAGE_TAG="2.1.0-26.04.1"

# =============================================================================
# AGENT STORAGE & REPORT CONFIGURATION
# =============================================================================
# Used by: vss-agent

VSS_ES_PORT=9200

# Object store type: local_object_store (in-memory, not persisted) or s3
VSS_AGENT_OBJECT_STORE_TYPE=local_object_store

# Base URL for report access
VSS_AGENT_EXTERNAL_URL=${VSS_PUBLIC_HTTP_PROTOCOL}://${VSS_PUBLIC_HOST}:${VSS_PUBLIC_PORT}
VSS_AGENT_REPORTS_BASE_URL=${VSS_PUBLIC_HTTP_PROTOCOL}://${VSS_PUBLIC_HOST}:${VSS_PUBLIC_PORT}/static/

# =============================================================================
# RTVI CONFIGURATION
# =============================================================================
# Used by: RTVI services (for bp_wh 2d mode)

# RTVI VLM Container Image tags for x86 and THOR
RTVI_VLM_IMAGE_TAG="3.2.0-26.04.2"
# Uncomment below RTVI VLM Container Image tag for DGX-SPARK
#RTVI_VLM_IMAGE_TAG="3.2.0-26.04.2-sbsa"

VLM_BASE_URL=http://${HOST_IP}:8018
RTVI_VLM_BASE_URL=http://${HOST_IP}:8018
RTVI_VLM_ENDPOINT=http://${HOST_IP}:8018/v1
RTVI_VLM_OPENAI_MODEL_DEPLOYMENT_NAME=${VLM_NAME}

RTVI_VLLM_GPU_MEMORY_UTILIZATION=''

# RTVI VLM Kafka Configuration
RTVI_VLM_KAFKA_BOOTSTRAP_SERVERS=${HOST_IP}:9092
RTVI_VLM_KAFKA_INCIDENT_TOPIC=mdx-vlm-incidents

# RTVI VLM input dimensions and frame rate (for DGX-SPARK, IGX-THOR, AGX-THOR only; not set on other platforms)
# RTVI_VLM_INPUT_WIDTH=860
# RTVI_VLM_INPUT_HEIGHT=467
# RTVI_VLM_DEFAULT_NUM_FRAMES_PER_SECOND_OR_FIXED_FRAMES_CHUNK=20

# =============================================================================
# PHOENIX TELEMETRY CONFIGURATION
# =============================================================================
# Used by: vss-agent

PHOENIX_ENDPOINT=http://${HOST_IP}:6006

# =============================================================================
# AGENT UI CONFIGURATION
# =============================================================================
# Used by: vss-ui

NEXT_PUBLIC_APP_TITLE="VSS BLUEPRINT"
NEXT_PUBLIC_APP_SUBTITLE="Warehouse"
NEXT_PUBLIC_ENABLE_CHAT_TAB=false
NEXT_PUBLIC_ENABLE_CHAT_SIDEBAR=true
NEXT_PUBLIC_SIDEBAR_CHAT_WORKFLOW="Warehouse Agent"
NEXT_PUBLIC_SIDEBAR_CHAT_CHAT_UPLOAD_FILE_ENABLE=false
NEXT_PUBLIC_ENABLE_ALERTS_TAB=true
NEXT_PUBLIC_ENABLE_DASHBOARD_TAB=true
NEXT_PUBLIC_ENABLE_MAP_TAB=false
NEXT_PUBLIC_ENABLE_VIDEO_MANAGEMENT_TAB=false
NEXT_PUBLIC_ENABLE_SEARCH_TAB=false
NEXT_PUBLIC_SIDEBAR_CHAT_CHAT_API_CUSTOM_AGENT_PARAMS_JSON={"params":[{"name":"llm_reasoning","label":"LLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""},{"name":"vlm_reasoning","label":"VLM Reasoning","type":"boolean","default-value":false,"changeable":true,"tooltip-info":""}]}

# =============================================================================
# BP CONFIGURATOR CONFIGURATION
# Used by: blueprint-configurator
# =============================================================================

# Enable/Disable Blueprint Profile Configurator. Set to true to enable, false to disable.
ENABLE_PROFILE_CONFIGURATOR=true

# Blueprint Profile Configurator config file for warehouse
CONFIGURATOR_CONFIG_FILE="blueprint_config.yml"

# Sensor Info Source: One of nvstreamer, msb or file
SENSOR_INFO_SOURCE=nvstreamer

# Path to file containing sensor info. Valid only if SENSOR_INFO_SOURCE=file
SENSOR_FILE_PATH=${MDX_SAMPLE_APPS_DIR}/industry-profiles/warehouse-operations/camera_configs/camera_info.json

# =============================================================================
# AUTO CALIBRATION CONFIGURATION
# =============================================================================
# Used by: vss-auto-calibration, vss-auto-calibration-ui

VSS_AUTO_CALIBRATION_PORT=8010
VGGT_MODEL_PATH=/tmp/vggt_model/vggt_1B_commercial.pt
VSS_AUTO_CALIBRATION_UI_PORT=5000
VSS_AUTO_CALIBRATION_MS_API_URL=http://${HOST_IP}:${VSS_AUTO_CALIBRATION_UI_PORT}/v1
VIOS_BASE_URL=${VST_INTERNAL_URL}

# =============================================================================
# VIDEO ANALYSIS MCP CONFIGURATION
# =============================================================================
# Used by: vss-agent video_analytics_mcp

VIDEO_ANALYSIS_MCP_URL=http://${HOST_IP}:${VSS_VA_MCP_PORT}