# =============================================================================
# COMPOSE DEFAULTS
# =============================================================================
# Default (empty) values for variables referenced across all compose files
# included in deploy/docker/compose.yml. These prevent docker-compose warnings
# when a profile does not use a particular service.
#
# Override any of these in your profile's .env when a real value is needed.
# =============================================================================

# Monitoring (Grafana)
GF_SECURITY_ADMIN_USER=''
GF_SECURITY_ADMIN_PASSWORD=''

# VST image tags (all platforms)
VST_INSTALL_ADDITIONAL_PACKAGES=''
VST_MCP_IMAGE_TAG=''
VST_STREAM_PROCESSOR_IMAGE_TAG=''
VST_SENSOR_IMAGE_TAG=''
VST_STORAGE_IMAGE_TAG=''
VST_RTSPSERVER_IMAGE_TAG=''
VST_RECORDER_IMAGE_TAG=''
VST_REPLAYSTREAM_IMAGE_TAG=''
VST_LIVESTREAM_IMAGE_TAG=''
NVSTREAMER_IMAGE_TAG=''
NVSTREAMER_HTTP_PORT=''
RTSP_SERVER_PORT=''
SAMPLE_VIDEO_DATASET=''
# Override in blueprint `.env`; compose interpolates ${VST_CONFIG_PATH:-${MDX_SAMPLE_APPS_DIR}/services/vios/configs} when unset.
VST_CONFIG_PATH=''
SDR_HTTP_REPLAYSTREAM_PORT=''
SDR_HTTP_LIVESTREAM_PORT=''
SENSOR_BP_WAIT_SDR_STREAM_MAX_SEC=''
BP_CONFIGURATOR_READYZ_URL=''
SENSOR_BP_WAIT_BP_CONFIGURATOR_MAX_SEC=''
SENSOR_BP_WAIT_STORAGE_MAX_SEC=''

