{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["$TURBO_EXTENDS$"],
      "outputs": ["$TURBO_EXTENDS$"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "bundle": {
      "dependsOn": ["build"],
      "inputs": ["public/**", "package.json"],
      "outputs": [".next/standalone/apps/nv-metropolis-bp-vss-ui/**"]
    }
  }
}
