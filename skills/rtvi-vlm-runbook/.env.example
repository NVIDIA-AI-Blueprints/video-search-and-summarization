# rtvi-vlm — copy to .env and fill in

# --- REQUIRED ---

# Host port for the REST API (strict sentinel in compose; no default)
RTVI_VLM_PORT=8018

# Host IP reachable from the container — Kafka bootstrap: ${HOST_IP}:9092
# (compose's extra_hosts also wires host.docker.internal)
HOST_IP=127.0.0.1

# MDX data root — compose bind-mounts ${MDX_DATA_DIR}/data_log/vst/clip_storage
# into /home/vst/vst_release/streamer_videos. No default → mount breaks if unset.
MDX_DATA_DIR=/abs/path/to/mdx-data

# NGC key — image pull + NIM auth. https://ngc.nvidia.com/setup/api-key
NGC_CLI_API_KEY=nvapi-REPLACE_ME

# --- MODEL (default wires to sibling NIM via OpenAI-compat; override for self-host) ---

RTVI_VLM_MODEL_TO_USE=openai-compat
# RTVI_VLM_MODEL_PATH=ngc:nim/nvidia/cosmos-reason2-8b:1208-fp8-static-kv8
# RTVI_VLM_ENDPOINT=https://your-endpoint/v1
# RTVI_VLM_OPENAI_MODEL_DEPLOYMENT_NAME=gpt-4o
# RTVI_VLM_API_KEY=  # overrides NGC_CLI_API_KEY for VIA_VLM_API_KEY if set

# --- GPU ---

# GPU index or UUID (from `nvidia-smi -L`). NOTE: RT_VLM_DEVICE_ID not RTVI_VLM_* —
# this name is fixed upstream in met-blueprints.
RT_VLM_DEVICE_ID=0
RTVI_VLM_NVIDIA_VISIBLE_DEVICES=all

# --- IMAGE (pin to a versioned tag for reproducibility) ---

RTVI_VLM_IMAGE_TAG=3.1.0

# --- OPTIONAL CREDENTIALS ---

# HF_TOKEN=hf_...                # Gated HuggingFace models (Qwen3-VL)
# OPENAI_API_KEY=sk-...          # Plain OpenAI when openai-compat
# OPENAI_API_VERSION=            # Azure OpenAI version pin
# NVIDIA_API_KEY=nvapi-...       # Generic NVIDIA API (else defaults to NOAPIKEYSET)

# --- STORAGE OVERRIDES (optional) ---

# ASSET_STORAGE_DIR=/abs/path/to/rtvi-assets    # default: tmpfs
# RTVI_VLM_LOG_DIR=/abs/path/to/rtvi-logs       # default: no host bind
# RTVI_VLM_HF_CACHE=/abs/path/to/hf             # default: named vol rtvi-hf-cache
# NGC_MODEL_CACHE=/abs/path/to/ngc-cache        # default: named vol rtvi-ngc-model-cache

# --- vLLM TUNING (override only when needed) ---

# RTVI_VLLM_GPU_MEMORY_UTILIZATION=             # empty → auto (0.7 if VRAM ≤ 50GB)
# RTVI_VLLM_MAX_NUM_SEQS=256
# RTVI_VLLM_MAX_NUM_BATCHED_TOKENS=5120
# RTVI_VLM_MAX_MODEL_LEN=32768
# RTVI_VLLM_NUM_SCHEDULER_STEPS=8
# RTVI_VLLM_ENABLE_PREFIX_CACHING=true
# RTVI_VLM_BATCH_SIZE=                          # empty → auto (128 for >80GB VRAM)

# --- KAFKA ---

RTVI_VLM_KAFKA_ENABLED=true
RTVI_VLM_KAFKA_TOPIC=vision-llm-messages
RTVI_VLM_KAFKA_INCIDENT_TOPIC=vision-llm-events-incidents
RTVI_VLM_ERROR_MESSAGE_TOPIC=vision-llm-errors

# --- RTSP ---

# RTVI_VLM_RTSP_LATENCY=
# RTVI_VLM_RTSP_TIMEOUT=
# RTVI_VLM_RTSP_RECONNECTION_INTERVAL=5
# RTVI_VLM_RTSP_RECONNECTION_WINDOW=60
# RTVI_VLM_RTSP_RECONNECTION_MAX_ATTEMPTS=10

# --- OBSERVABILITY ---

RTVI_VLM_ENABLE_OTEL_MONITORING=false
# RTVI_VLM_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# --- REDIS (optional, for error channel) ---

# ENABLE_REDIS_ERROR_MESSAGES=false
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# --- LOGGING / MISC ---

RTVI_VLM_LOG_LEVEL=INFO
INSTALL_PROPRIETARY_CODECS=false
# FORCE_SW_AV1_DECODER=
# VSS_SKIP_INPUT_MEDIA_VERIFICATION=
# RTVI_EXTRA_ARGS=
