# Required: Slack Bot OAuth Token (xoxb-...)
# Create a Slack App at https://api.slack.com/apps, enable Bot Token Scopes: chat:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Required: Slack Channel ID (e.g. C07XXXXXXXX)
# Right-click channel in Slack -> "View channel details" -> copy Channel ID at bottom
SLACK_CHANNEL_ID=C0000000000

# Optional: Webhook server host and port
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=9090

# Required: VST endpoint for video clip URL resolution (host:port, no http:// prefix)
# The agent resolves this via vios-api when starting the webhook.
VST_ENDPOINT=10.63.144.174:30888
